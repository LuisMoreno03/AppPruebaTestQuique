<div id="editor-cuadros-{{ block.id }}" class="editor-container">

  <!-- PASO 1: Zona de upload -->
  <div id="zona-upload-{{ block.id }}" class="zona-upload">
    <h3>{{ block.settings.titulo_editor }}</h3>
    <p>Sube tu foto y ve el resultado en segundos ✨</p>
    <label for="input-foto-{{ block.id }}" class="boton-upload">
      📷 Subir mi foto
    </label>
    <input
      type="file"
      id="input-foto-{{ block.id }}"
      accept="image/*"
      style="display:none"
    />
  </div>

  <!-- PASO 2: Loader mientras la IA procesa -->
  <div id="zona-loader-{{ block.id }}" class="zona-loader" style="display:none">
  <p>Generando tu diseño con IA... ✨</p>
  <div class="barra-contenedor">
    <div id="barra-progreso-{{ block.id }}" class="barra-progreso"></div>
  </div>
  <p id="texto-progreso-{{ block.id }}" class="texto-progreso">0%</p>
</div>

  <!-- PASO 3: Resultado -->
  <div id="zona-resultado-{{ block.id }}" class="zona-resultado" style="display:none">
    <img id="imagen-resultado-{{ block.id }}" src="" alt="Tu diseño personalizado" style="display:none" />
    <div class="botones-resultado">
      <button id="boton-reintentar-{{ block.id }}" class="boton-secundario">
        🔄 Intentar de nuevo
      </button>
      <button id="boton-confirmar-{{ block.id }}" class="boton-principal">
        ✅ Diseño confirmado
      </button>
    </div>
  </div>

</div>

<style>
  .editor-container {
    padding: 20px;
    border: 2px dashed #ccc;
    border-radius: 12px;
    text-align: center;
    margin: 20px 0;
  }
  .boton-upload {
    display: inline-block;
    padding: 12px 24px;
    background: {{ block.settings.color_boton }};
    color: white;
    border-radius: 8px;
    cursor: pointer;
    font-size: 16px;
    margin-top: 12px;
  }
    .barra-contenedor {
    width: 100%;
    background: #f0f0f0;
    border-radius: 20px;
    height: 12px;
    margin: 16px 0 8px 0;
    overflow: hidden;
  }
  .barra-progreso {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #000, #555);
    border-radius: 20px;
    transition: width 0.4s ease;
  }
  .texto-progreso {
    font-size: 13px;
    color: #666;
    margin: 0;
  }
  .botones-resultado {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 16px;
  }
  .boton-principal {
    padding: 12px 24px;
    background: #000;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 16px;
  }
  .boton-secundario {
    padding: 12px 24px;
    background: white;
    color: #000;
    border: 2px solid #000;
    border-radius: 8px;
    cursor: pointer;
    font-size: 16px;
  }
</style>

<script>
  (function() {
    var blockId = '{{ block.id }}';
    var inputFoto     = document.getElementById('input-foto-' + blockId);
    var zonaUpload    = document.getElementById('zona-upload-' + blockId);
    var zonaLoader    = document.getElementById('zona-loader-' + blockId);
    var zonaResultado = document.getElementById('zona-resultado-' + blockId);
    var imagenResultado  = document.getElementById('imagen-resultado-' + blockId);
    var botonReintentar  = document.getElementById('boton-reintentar-' + blockId);
    var botonConfirmar   = document.getElementById('boton-confirmar-' + blockId);

    var intentos = 0;
    var MAX_INTENTOS = 3;

    function mostrarZona(zona) {
      zonaUpload.style.display    = zona === 'upload'    ? 'block' : 'none';
      zonaLoader.style.display    = zona === 'loader'    ? 'block' : 'none';
      zonaResultado.style.display = zona === 'resultado' ? 'block' : 'none';
    }

    function convertirABase64(archivo) {
      return new Promise(function(resolve, reject) {
        var reader = new FileReader();
        reader.onload  = function() { resolve(reader.result.split(',')[1]); };
        reader.onerror = function() { reject(new Error('Error leyendo archivo')); };
        reader.readAsDataURL(archivo);
      });
    }

    inputFoto.addEventListener('change', function(e) {
      var foto = e.target.files[0];
      if (!foto || !foto.type.startsWith('image/')) {
        alert('Por favor selecciona una imagen válida');
        return;
      }
      if (foto.size > 10 * 1024 * 1024) {
        alert('La imagen es demasiado grande. Máximo 10MB');
        return;
      }
            intentos++;
      mostrarZona('loader');

      var barra = document.getElementById('barra-progreso-' + blockId);
      var textoPorcentaje = document.getElementById('texto-progreso-' + blockId);
      var progreso = 0;
      barra.style.width = '0%';
      barra.style.transition = 'none';

      var mensajes = [
        'Analizando tu foto...',
        'Aplicando el estilo IA...',
        'Generando los detalles...',
        'Casi listo...',
        '¡Tu diseño está listo! ✨'
      ];

      var intervalo = setInterval(function() {
        if (progreso === 0) barra.style.transition = 'width 0.4s ease';
        var incremento = progreso < 60 ? 5 : progreso < 85 ? 2 : 0.5;
        progreso = Math.min(progreso + incremento, 95);
        barra.style.width = progreso + '%';
        textoPorcentaje.textContent = mensajes[Math.floor(progreso / 20)] || mensajes[4];
      }, 100);

      // Enviar foto al servidor de IA
      var formData = new FormData();
      formData.append('imagen', foto);

      fetch('http://187.77.96.150/api/generar-diseno', {
        method: 'POST',
        body: formData
      })
      .then(function(respuesta) {
        return respuesta.json();
      })
      .then(function(datos) {
        clearInterval(intervalo);
        barra.style.width = '100%';
        textoPorcentaje.textContent = '¡Tu diseño está listo! ✨';

        setTimeout(function() {
          imagenResultado.src = datos.imagen_url;
          mostrarZona('resultado');

          var contenedorImagen = document.querySelector('.product__media-wrapper');
          if (contenedorImagen) {
            var imgOriginal = contenedorImagen.querySelector('img');
            var anchura = imgOriginal ? imgOriginal.clientWidth + 'px' : '100%';
            var altura = imgOriginal ? imgOriginal.clientHeight + 'px' : 'auto';
            contenedorImagen.innerHTML = '<img src="' + datos.imagen_url + '" style="width:' + anchura + ';height:' + altura + ';object-fit:cover;border-radius:8px;" />';
          }

          if (intentos >= MAX_INTENTOS) {
            botonReintentar.style.display = 'none';
          }
        }, 300);
      })
      .catch(function(error) {
        clearInterval(intervalo);
        console.error('Error:', error);
        mostrarZona('upload');
        alert('Hubo un problema generando tu diseño. Por favor intenta de nuevo.');
      });
    });


    botonReintentar.addEventListener('click', function() {
      mostrarZona('upload');
      inputFoto.value = '';
    });

    botonConfirmar.addEventListener('click', function() {
      alert('¡Diseño confirmado! Aquí irá la integración con el carrito.');
    });

  })();
</script>

{% schema %}
{
  "name": "Editor de Diseños IA",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "titulo_editor",
      "label": "Título del editor",
      "default": "Personaliza tu cuadro"
    },
    {
      "type": "color",
      "id": "color_boton",
      "label": "Color del botón",
      "default": "#000000"
    }
  ]
}
{% endschema %}